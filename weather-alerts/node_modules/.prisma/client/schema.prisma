generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int     @id @default(autoincrement())
  name            String
  email           String  @unique
  phoneNumber     String?
  alertPreference String  @default("email")
  plants          Plant[]
  alerts          Alert[]
}

model Plant {
  id                 Int          @id @default(autoincrement())
  plantName          String
  plantType          String
  optimalMoisture    Float
  optimalLight       Float
  optimalTemperature Float
  location           String?
  userId             Int
  user               User         @relation(fields: [userId], references: [id])
  sensorData         SensorData[]
}

model SensorData {
  id             Int      @id @default(autoincrement())
  timestamp      DateTime @default(now())
  temperature    Float
  humidity       Float
  soilMoisture   Float
  lightIntensity Float
  plantId        Int
  plant          Plant    @relation(fields: [plantId], references: [id])
}

model WeatherData {
  id          Int      @id @default(autoincrement())
  temperature Float
  humidity    Float
  forecast    String
  location    String
  timestamp   DateTime @default(now())
}

model Alert {
  id             Int      @id @default(autoincrement())
  message        String
  alertType      String
  timestamp      DateTime @default(now())
  deliveryMethod String
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
}
